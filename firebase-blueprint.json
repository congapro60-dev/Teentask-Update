{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["student", "parent", "business", "admin"] },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "verificationStatus": { "type": "string", "enum": ["unverified", "pending", "verified", "rejected"] },
        "fullName": { "type": "string" },
        "idNumber": { "type": "string" },
        "idCardPhoto": { "type": "string" },
        "dob": { "type": "string" },
        "parentEmail": { "type": "string", "format": "email" },
        "trustScore": { "type": "number" },
        "bio": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "paymentCode": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Job": {
      "title": "Job Posting",
      "description": "Freelance jobs for Gen Z.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "businessId": { "type": "string" },
        "businessName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "salary": { "type": "number" },
        "slotsTotal": { "type": "number" },
        "slotsFilled": { "type": "number" },
        "deadline": { "type": "number" },
        "location": { "type": "string" },
        "type": { "type": "string", "enum": ["online", "offline"] },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "closed"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "businessId", "title", "salary", "deadline", "status", "createdAt"]
    },
    "ShadowingEvent": {
      "title": "Shadowing Event",
      "description": "Job shadowing opportunities.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "mentorId": { "type": "string" },
        "mentorName": { "type": "string" },
        "companyName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "number" },
        "price": { "type": "number" },
        "slotsTotal": { "type": "number" },
        "slotsRemaining": { "type": "number" },
        "location": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "mentorId", "title", "date", "price", "createdAt"]
    },
    "Application": {
      "title": "Job Application",
      "description": "Student applications for jobs.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "jobId": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "portfolioUrl": { "type": "string" },
        "parentStatus": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "finalStatus": { "type": "string", "enum": ["pending", "accepted", "rejected", "completed"] },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "jobId", "studentId", "parentStatus", "finalStatus", "createdAt"]
    },
    "Chat": {
      "title": "Chat Conversation",
      "description": "A conversation between two users.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "participantDetails": { "type": "object" },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "number" },
        "relatedTo": { "type": "object" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "participants", "createdAt"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A single message in a chat.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "chatId", "senderId", "text", "createdAt"]
    },
    "Review": {
      "title": "Company Review",
      "description": "Student reviews for businesses.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "businessId": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "studentPhoto": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "jobId": { "type": "string" },
        "jobTitle": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "businessId", "studentId", "rating", "comment", "jobId", "createdAt"]
    },
    "Rating": {
      "title": "Trust Rating",
      "description": "Ratings given by students/parents to businesses or vice versa after a transaction.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fromId": { "type": "string" },
        "fromName": { "type": "string" },
        "toId": { "type": "string" },
        "jobId": { "type": "string" },
        "score": { "type": "number", "minimum": 1, "maximum": 5 },
        "comment": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "fromId", "toId", "score", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app notification for users.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "applicationId": { "type": "string" },
        "createdAt": { "type": "number" },
        "read": { "type": "boolean" }
      },
      "required": ["id", "userId", "title", "message", "createdAt", "read"]
    },
    "Transaction": {
      "title": "Wallet Transaction",
      "description": "A transaction in the user's wallet.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "withdrawal", "payment", "reward"] },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "description": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "userId", "type", "amount", "status", "description", "createdAt"]
    },
    "CV": {
      "title": "Curriculum Vitae",
      "description": "Student CV for job applications.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "summary": { "type": "string" },
        "education": { "type": "array" },
        "experience": { "type": "array" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "projects": { "type": "array" },
        "languages": { "type": "array", "items": { "type": "string" } },
        "lastUpdated": { "type": "number" }
      },
      "required": ["id", "userId", "fullName", "email", "lastUpdated"]
    },
    "ShadowingBooking": {
      "title": "Shadowing Booking",
      "description": "Student booking for a shadowing event.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "eventId": { "type": "string" },
        "eventTitle": { "type": "string" },
        "eventDate": { "type": "string" },
        "company": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "userId", "eventId", "eventTitle", "eventDate", "status", "createdAt"]
    },
    "Course": {
      "title": "Skill Course",
      "description": "Educational courses for students.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "provider": { "type": "string" },
        "imageUrl": { "type": "string" },
        "price": { "type": "number" },
        "registeredCount": { "type": "number" },
        "totalSlots": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "title", "provider", "price", "status", "createdAt"]
    },
    "Event": {
      "title": "Calendar Event",
      "description": "Events for the calendar widget.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "number" },
        "location": { "type": "string" },
        "type": { "type": "string", "enum": ["workshop", "shadowing", "other"] },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "title", "date", "type", "status", "createdAt"]
    },
    "ShadowingTask": {
      "title": "Shadowing Task",
      "description": "Structured tasks for shadowing students.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "businessId": { "type": "string" },
        "businessName": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "daysToComplete": { "type": "number" },
        "outputRequired": { "type": "string" },
        "skillsLearned": { "type": "string" },
        "maxStudents": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "closed"] },
        "createdAt": { "type": "number" }
      },
      "required": ["businessId", "name", "description", "daysToComplete", "outputRequired", "skillsLearned", "status", "createdAt"]
    },
    "ShadowingWorkshop": {
      "title": "Shadowing Workshop",
      "description": "Group workshops for students.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "businessId": { "type": "string" },
        "businessName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "number" },
        "time": { "type": "string" },
        "price": { "type": "number" },
        "slotsTotal": { "type": "number" },
        "slotsRemaining": { "type": "number" },
        "location": { "type": "string" },
        "skills": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "closed"] },
        "createdAt": { "type": "number" }
      },
      "required": ["businessId", "title", "date", "slotsTotal", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles by UID."
    },
    "jobs/{jobId}": {
      "schema": "Job",
      "description": "Job postings."
    },
    "shadowing_events/{eventId}": {
      "schema": "ShadowingEvent",
      "description": "Shadowing events."
    },
    "applications/{applicationId}": {
      "schema": "Application",
      "description": "Job applications."
    },
    "chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat conversations."
    },
    "chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a chat."
    },
    "reviews/{reviewId}": {
      "schema": "Review",
      "description": "Company reviews."
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "In-app notifications for users."
    },
    "ratings/{ratingId}": {
      "schema": "Rating",
      "description": "Trust ratings between users."
    },
    "transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Wallet transactions."
    },
    "cvs/{cvId}": {
      "schema": "CV",
      "description": "Student CVs."
    },
    "shadowing_bookings/{bookingId}": {
      "schema": "ShadowingBooking",
      "description": "Shadowing event bookings."
    },
    "courses/{courseId}": {
      "schema": "Course",
      "description": "Skill building courses."
    },
    "events/{eventId}": {
      "schema": "Event",
      "description": "Calendar events."
    },
    "shadowing_tasks/{taskId}": {
      "schema": "ShadowingTask",
      "description": "Structured shadowing tasks."
    },
    "shadowing_workshops/{workshopId}": {
      "schema": "ShadowingWorkshop",
      "description": "Group shadowing workshops."
    }
  }
}
