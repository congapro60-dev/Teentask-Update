# --- AI & GENERAL ---
# GEMINI_API_KEY: Required for Gemini AI assistant features.
GEMINI_API_KEY=

# --- EMAIL & PAYMENTS ---
# Gmail address used to send reminders
EMAIL_USER=
# Gmail App Password (NOT your main password)
EMAIL_PASS=

# SePay API Key for webhook authentication
SEPAY_API_KEY=

# --- ADVANCED (OPTIONAL) ---
# FIREBASE_SERVICE_ACCOUNT: JSON string of your Firebase Service Account.
# Required only for server-side admin tasks (like automated email reminders).
FIREBASE_SERVICE_ACCOUNT=
