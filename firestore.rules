rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, role, displayName, photoURL, dob, parentEmail, trustScore, bio, skills, createdAt
    //
    // Collection: jobs
    // Fields: id, businessId, businessName, title, description, salary, slotsTotal, slotsFilled, deadline, location, type, category, status, tags, createdAt
    //
    // Collection: shadowing_events
    // Fields: id, mentorId, mentorName, mentorTitle, companyId, companyName, title, description, date, time, price, slotsTotal, slotsRemaining, location, category, type, status, level, requirements, benefits, createdAt
    //
    // Collection: practical_tasks
    // Fields: id, businessId, businessName, title, description, durationDays, requiredOutput, skillsGained, maxStudents, currentStudents, status, createdAt
    //
    // Collection: task_submissions
    // Fields: id, taskId, studentId, studentName, outputUrl, feedback, status, submittedAt
    //
    // Collection: applications
    // Fields: id, jobId, businessId, studentId, studentName, parentEmail, portfolioUrl, parentStatus, finalStatus, createdAt
    //
    // Collection: reviews
    // Fields: id, businessId, studentId, studentName, studentPhoto, rating, comment, jobId, jobTitle, createdAt
    //
    // Collection: advertisements
    // Fields: id, businessId, businessName, title, description, imageUrl, linkUrl, status, createdAt
    //
    // Collection: support_messages
    // Fields: id, userId, userName, userEmail, subject, message, reply, status, createdAt
    //
    // Collection: cvs
    // Fields: id, userId, fullName, email, phone, address, summary, education, experience, skills, projects, languages, lastUpdated
    //
    // Collection: shadowing_bookings
    // Fields: id, userId, eventId, eventTitle, eventDate, company, status, createdAt
    //
    // Collection: name_change_requests
    // Fields: id, userId, oldName, newName, reason, proofUrl, status, createdAt
    //
    // Collection: friend_requests
    // Fields: id, fromId, toId, status, createdAt
    //
    // Collection: relationships
    // Fields: id, userId, relatedUserId, type, title, status, createdAt
    //
    // Collection: transactions
    // Fields: id, userId, amount, type, description, status, createdAt
    //
    // Collection: courses
    // Fields: id, title, provider, imageUrl, price, registeredCount, totalSlots, status, createdAt
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData().role == role;
    }

    function isBoss() {
      return isAuthenticated() && request.auth.token.email == "congapro60@gmail.com";
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin') ||
         isBoss() ||
         (request.auth.token.email == "cuong.vuviet@thedeweyschools.edu.vn") ||
         (request.auth.token.email == "vuvietcuonglmnx@gmail.com"));
    }

    function isBusiness() {
      return hasRole('business');
    }

    function isParent() {
      return hasRole('parent');
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /_connection_test_/{id} {
      allow read: if true;
    }

    match /users/{userId} {
      allow get: if true;
      allow list: if isAuthenticated() || resource.data.role in ['business', 'parent'];
      allow create: if isOwner(userId);
      allow update: if isBoss() || 
                    (isAdmin() && resource.data.email != "congapro60@gmail.com") ||
                    (isOwner(userId) && 
                      !request.resource.data.diff(resource.data).affectedKeys().hasAny(['trustScore', 'balance']) &&
                      (request.resource.data.role == resource.data.role || (resource.data.role != 'admin' && request.resource.data.role != 'admin'))
                    );
    }

    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
                    request.resource.data.fromId == request.auth.uid &&
                    request.resource.data.fromId != request.resource.data.toId &&
                    request.resource.data.score >= 1 && request.resource.data.score <= 5;
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /jobs/{jobId} {
      allow read: if resource.data.status == 'active' || isAuthenticated();
      allow create: if isAuthenticated() && (isBusiness() || isAdmin() || isParent());
      allow update: if isAdmin() || (isAuthenticated() && resource.data.businessId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /shadowing_events/{eventId} {
      allow read: if true;
      allow create: if isAuthenticated() && (isBusiness() || isAdmin() || isParent());
      allow update: if isAdmin() || (isAuthenticated() && resource.data.mentorId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /practical_tasks/{taskId} {
      allow read: if true;
      allow create: if isAuthenticated() && (isBusiness() || isAdmin());
      allow update: if isAdmin() || (isAuthenticated() && resource.data.businessId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /task_submissions/{submissionId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.studentId || 
        isAdmin() ||
        // Allow the business who owns the task to read submissions
        exists(/databases/$(database)/documents/practical_tasks/$(resource.data.taskId)) &&
        get(/databases/$(database)/documents/practical_tasks/$(resource.data.taskId)).data.businessId == request.auth.uid
      );
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.studentId ||
        isAdmin() ||
        exists(/databases/$(database)/documents/practical_tasks/$(resource.data.taskId)) &&
        get(/databases/$(database)/documents/practical_tasks/$(resource.data.taskId)).data.businessId == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    match /applications/{applicationId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.studentId || 
        resource.data.businessId == request.auth.uid ||
        request.auth.token.email == resource.data.parentEmail ||
        isAdmin() || isParent()
      );
      allow create: if isAuthenticated() && (request.resource.data.studentId == request.auth.uid || isParent());
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.studentId ||
        resource.data.businessId == request.auth.uid ||
        request.auth.token.email == resource.data.parentEmail ||
        isAdmin() || isParent()
      );
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
        request.resource.data.studentId == request.auth.uid &&
        request.resource.data.rating >= 1 && request.resource.data.rating <= 5;
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && (
        isAdmin() || 
        isParent() ||
        request.resource.data.userId == request.auth.uid ||
        (request.resource.data.keys().hasAll(['userId', 'title', 'message', 'type', 'createdAt', 'read']) &&
         request.resource.data.read == false &&
         request.resource.data.createdAt <= request.time.toMillis())
      );
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    match /chats/{chatId} {
      // Allow get if user is participant or if it's a new bot chat for them
      allow get: if isAuthenticated() && (
        (resource != null && request.auth.uid in resource.data.participants) ||
        (resource == null && chatId.matches(".*" + request.auth.uid + ".*"))
      );
      // Allow list only if filtered by participants
      allow list: if isAuthenticated() && request.auth.uid in resource.data.participants;
      
      allow create: if isAuthenticated() && 
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.participants.size() >= 2;
        
      allow update: if isAuthenticated() && 
        request.auth.uid in resource.data.participants &&
        (isAdmin() || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessage', 'lastMessageAt']));

      match /messages/{messageId} {
        allow read: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
          
        allow create: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          (request.resource.data.senderId == request.auth.uid || request.resource.data.senderId == 'teentask-bot') &&
          request.resource.data.chatId == chatId;
      }
    }

    match /advertisements/{adId} {
      allow read: if resource.data.status == 'approved' || isAdmin() || (isAuthenticated() && resource.data.businessId == request.auth.uid);
      allow create: if isAuthenticated() && isBusiness();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /support_messages/{msgId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /survey_responses/{responseId} {
      allow read: if true; // Allow public read for stats (Social Proof). NOTE: Contains email field.
      allow create: if true; // Allow anyone (even guests) to submit surveys as requested
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /quick_surveys/{surveyId} {
      allow read: if true;
      allow create: if true 
                    && request.resource.data.keys().hasAll(['role', 'createdAt'])
                    && request.resource.data.role in ['student', 'parent', 'business']
                    && request.resource.data.createdAt is number;
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /friend_requests/{requestId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.fromId || request.auth.uid == resource.data.toId);
      allow create: if isAuthenticated() && request.resource.data.fromId == request.auth.uid;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.fromId || request.auth.uid == resource.data.toId);
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.fromId || request.auth.uid == resource.data.toId);
    }

    match /relationships/{relId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.relatedUserId);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /cvs/{cvId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /shadowing_bookings/{bookingId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /name_change_requests/{requestId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /market_surveys/{surveyId} {
      allow read: if true; // Allow public read for market trends
      allow create: if isAuthenticated() 
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.keys().hasAll(['userId', 'role', 'createdAt'])
                    && request.resource.data.role in ['student', 'parent', 'business'];
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
